# Copy this file to `.env` and adjust values for your local setup.
# Real environment variables always take precedence over values in `.env`.

# --- Keycloak / OIDC bearer authentication (required for the API) ---
# Values below match the bundled docker-compose Keycloak (realm "sgdypa",
# API client "sgdypa-api" on port 8080).
KEYCLOAK_OIDC_ISSUER=http://localhost:8080/realms/sgdypa
KEYCLOAK_OIDC_AUDIENCE=sgdypa-api
KEYCLOAK_OIDC_JWKS_URL=http://localhost:8080/realms/sgdypa/protocol/openid-connect/certs
# Comma-separated list of accepted signing algorithms.
KEYCLOAK_OIDC_ALGORITHMS=RS256

# --- Keycloak -> backend replication webhook ---
# Shared secret used to HMAC-sign admin-event webhook payloads. Must match the
# secret configured on the Keycloak webhook event listener (see README). Leave
# unset to disable the endpoint (it fails closed with 503).
KEYCLOAK_WEBHOOK_SECRET=dev-webhook-secret-change-me
# Header carrying the hex HMAC-SHA256 signature of the raw request body.
KEYCLOAK_WEBHOOK_SIGNATURE_HEADER=X-Keycloak-Signature
# URL the Keycloak webhook SPI (docker/keycloak/spi) POSTs admin events to.
# Default targets the host-run app from inside the Keycloak container.
KEYCLOAK_WEBHOOK_TARGET_URL=http://host.docker.internal:8000/api/v1/identity/keycloak/events

# --- Keycloak group -> Organization replication ---
# When true, a user's Keycloak group membership auto-creates local Organizations
# and Memberships, and their mapped roles become P1-P7 roles. Reconciled at login
# and via GROUP_MEMBERSHIP admin events. OFF by default (fails safe). Requires a
# "Full group path" Group Membership token mapper and realm/client role scopes.
KEYCLOAK_ORG_REPLICATION_ENABLED=false
# Token claim carrying the user's group paths (from the group membership mapper).
KEYCLOAK_GROUPS_CLAIM=groups
# JSON object mapping Keycloak role names -> local P1-P7 codes, e.g.
# {"auditor-lider":"P1","tenant-admin":"P6"}. Roles are global across the user's orgs.
KEYCLOAK_ROLE_MAP={}

# --- CORS (browser cross-origin access from the SPA) ---
# Comma-separated list of allowed frontend origins (scheme + host + port). The
# Vite dev server default (http://localhost:5173) is applied automatically in dev
# when this is unset; set it explicitly in stage/prod, e.g.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# --- Database ---
# DB_ENGINE: "sqlite3" (default) or "postgres" to use the docker-compose Postgres.
DB_ENGINE=sqlite3
# The POSTGRES_* values are only used when DB_ENGINE is a Postgres engine.
POSTGRES_DB=sgdypa
POSTGRES_USER=sgdypa
POSTGRES_PASSWORD=sgdypa_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer
POSTGRES_CONN_MAX_AGE=60
